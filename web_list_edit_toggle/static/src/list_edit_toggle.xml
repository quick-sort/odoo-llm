<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.ListView" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o_list_button_add')]" position="after">
            <button t-if="_archEditable and !editToggleState.active and props.showButtons"
                    type="button"
                    class="btn btn-secondary o_list_button_edit_toggle ms-1"
                    t-on-click="toggleEditMode">
                Edit
            </button>
            <button t-if="_archEditable and editToggleState.active and props.showButtons"
                    type="button"
                    class="btn btn-primary o_list_button_edit_toggle ms-1"
                    t-on-click="toggleEditMode">
                Quit Editing
            </button>
        </xpath>
    </t>
</templates>
